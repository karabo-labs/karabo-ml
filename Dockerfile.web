# Multi-stage: builder + web runtime
FROM python:3.11-slim AS builder

WORKDIR /build

RUN pip install --no-cache-dir --upgrade pip build hatchling

COPY pyproject.toml README.md ./
COPY src/ ./src/

RUN python -m build --wheel

FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install kb CLI + web deps
COPY --from=builder /build/dist/*.whl /tmp/
RUN pip install --no-cache-dir /tmp/karabo_ml-*.whl "fastapi>=0.133.0" "uvicorn[standard]>=0.41.0" "jinja2>=3.1.0" "python-multipart>=0.0.9" && \
    rm /tmp/karabo_ml-*.whl

# Copy web app
COPY web/ ./web/

RUN addgroup --system kb && adduser --system --ingroup kb kbuser
USER kbuser

EXPOSE 8080

CMD ["uvicorn", "web.main:app", "--host", "0.0.0.0", "--port", "8080"]
